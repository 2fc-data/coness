ssName='line1'></div>\n            <div className='line2'></div>\n            <div className='line3'></div>\n          </div>\n        </div>\n      \n        <ul className={active}>\n          {navItems.map((item) => (\n            <li key={item.id} className='nav__item'>\n              <Link to={item.href} onClick={navToggle} className='nav__link'>{item.label}</Link>\n            </li>\n            ))}\n        </ul>\n      </div>\n\n\n      <div className='inner-wrapper'>\n        <Link to=\"/\"> \n          <Styled.Logo alt=\"Essencial - Construtora e Incorporadora\"/>\n        </Link>\n      </div>\n\n      <div className='inner-wrapper'>\n        <div className='nav__contact'>\n          <u>Vendas:</u>\n          <p>\n            <BsWhatsapp />\n            <a \n              href=\"https://api.whatsapp.com/send?phone=5535988893840&text=Olá,%20Tenho%20interesse%20em%20saber%20mais%20sobre%20os%20empreendimentos,%20da%20Essencial%20Construtora,%20obrigado!\" \n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n            >\n              <p className='nav__contact--whatsapp'>(35) 98889-3840</p>\n            </a>\n          </p>\n\n          <p>\n            <BsTelephone />\n            <p className='nav__contact--fone'>(35) 3722-3840</p>\n          </p>\n        </div>\n      </div>\n    </Styled.MainNav>\n  );\n}\n\nexport default MainNav;\n","/Users/Fernando/Documents/www/ConstrutoraEssencial/dev2fc/coness/src/components/FooterBottom/FooterBottom.component.jsx",["518"],[],"/Users/Fernando/Documents/www/ConstrutoraEssencial/dev2fc/coness/src/components/Footer/Footer.component.jsx",[],[],"/Users/Fernando/Documents/www/ConstrutoraEssencial/dev2fc/coness/src/components/ResidencialCarmoRibeiro/ResidencialCarmoRibeiro.component.js",[],[],[],"/Users/Fernando/Documents/www/ConstrutoraEssencial/dev2fc/coness/src/components/Contato/Contato.component.jsx",[],[],"/Users/Fernando/Documents/www/ConstrutoraEssencial/dev2fc/coness/src/components/Emp